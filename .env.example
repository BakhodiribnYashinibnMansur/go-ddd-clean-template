# App
APP_NAME=go-clean-template
APP_VERSION=1.0.0

# Security - CSRF Protection
# Generate a strong random secret (minimum 32 characters)
# Example: openssl rand -base64 32
CSRF_SECRET=your-csrf-secret-key-min-32-chars-change-in-production

# HTTP settings
HTTP_PORT=8080
HTTP_USE_PREFORK_MODE=false

# Logger
LOG_LEVEL=debug

# PG
PG_POOL_MAX=2
PG_HOST=localhost
PG_PORT=5432
PG_NAME=db
PG_USER=user
PG_PASSWORD=pass

# Mongo
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_NAME=db
MONGO_USER=user
MONGO_PASSWORD=pass

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_NAME=0 # Database index, or name
REDIS_USER=
REDIS_PASSWORD=

# Minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_REGION=us-east-1
MINIO_BUCKET=my-bucket

# JWT
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
JWT_ISSUER=auth-service
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""

# gRPC
GRPC_PORT=8081

# RMQ
RMQ_RPC_SERVER=rpc_server
RMQ_RPC_CLIENT=rpc_client
RMQ_URL=amqp://guest:guest@localhost:5672/

# NATS
NATS_RPC_SERVER=rpc_server
NATS_URL=nats://guest:guest@localhost:4222/

# Metrics
METRICS_ENABLED=true

# Swagger
SWAGGER_ENABLED=true
PROTO_DOCS_ENABLED=true