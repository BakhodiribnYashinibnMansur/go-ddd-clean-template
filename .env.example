# App
APP_NAME=go-clean-template
APP_VERSION=1.0.0

# Security - CSRF Protection
# Generate a strong random secret (minimum 32 characters)
# Example: openssl rand -base64 32
CSRF_SECRET=your-csrf-secret-key-min-32-chars-change-in-production

# HTTP settings
HTTP_PORT=8080
HTTP_USE_PREFORK_MODE=false

# Logger
LOG_LEVEL=debug

# PG
PG_POOL_MAX=2
PG_HOST=localhost
PG_PORT=5432
PG_NAME=db
PG_USER=user
PG_PASSWORD=pass

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_NAME=0 # Database index, or name
REDIS_USER=
REDIS_PASSWORD=

# Minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_REGION=us-east-1
MINIO_BUCKET=my-bucket

# JWT
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
JWT_ISSUER=auth-service
JWT_PRIVATE_KEY=""
JWT_PUBLIC_KEY=""

# Metrics
METRICS_ENABLED=true

# Swagger
SWAGGER_ENABLED=true
PROTO_DOCS_ENABLED=true

# Tracing
TRACING_ENABLED=false
TRACING_SERVICE_NAME=go-clean-template
TRACING_ENDPOINT=http://localhost:14268/api/traces
TRACING_INSECURE=true
# Rate Limiting
LIMITER_ENABLED=true
LIMITER_LIMIT=100
LIMITER_PERIOD=M

# Feature Flags
FEATURE_FLAG_ENABLED=true
FEATURE_FLAG_CONFIG_PATH=./config/flags.yaml
FEATURE_FLAG_POLLING_INTERVAL=60
FEATURE_FLAG_USE_FILE=true
FEATURE_FLAG_USE_REDIS=false
FEATURE_FLAG_REDIS_KEY=feature_flags

# Asynq - Background Job Queue
ASYNQ_ADDR=
ASYNQ_PASSWORD=
ASYNQ_DB=0
ASYNQ_CONCURRENCY=10
ASYNQ_MAX_RETRY=3
ASYNQ_WORKER_ENABLED=true

# Seeder
SEEDER_ENABLED=false
SEEDER_USERS_COUNT=50
SEEDER_ROLES_COUNT=10
SEEDER_PERMISSIONS_COUNT=20
SEEDER_SEED=0
SEEDER_CLEAR_DATA=false

